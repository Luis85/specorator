# Dependencies
node_modules/

# Build output — Obsidian plugin bundle (output to project root by convention)
main.js
main.js.map

# Standalone UI build
dist-standalone/

# TypeScript incremental build info
*.tsbuildinfo

# OS / editor
.DS_Store
Thumbs.db
.idea/
